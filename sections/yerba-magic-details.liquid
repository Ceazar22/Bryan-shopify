{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  /* ---- Palette: 3 brand colors (green / pink / gold) + 2 neutrals ---- */
  .ym-{{ section.id }} {
    --ym-green: #3F4D32;
    --ym-green-soft: #7E8F5B;
    --ym-pink: #E0568C;
    --ym-gold: #D4AF37;
    --ym-ink: #15131A;
    --ym-cream: #FBF6EE;
    --ym-radius: clamp(1.6rem, 2.4vw, 2.4rem);
    --ym-font-head: 'Recoleta', 'Fraunces', 'Playfair Display', Georgia, 'Times New Roman', serif;
    --ym-font-body: 'Volte', 'Mulish', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    font-family: var(--ym-font-body);
  }

  .ym-{{ section.id }} h2,
  .ym-{{ section.id }} h3,
  .ym-{{ section.id }} .title,
  .ym-{{ section.id }} .h0,
  .ym-{{ section.id }} .h1,
  .ym-{{ section.id }} .h2,
  .ym-{{ section.id }} .h3,
  .ym-{{ section.id }} .h4 {
    font-family: var(--ym-font-head);
    letter-spacing: -0.01em;
  }

  .ym-{{ section.id }} .ym-ico { width: 2.2rem; height: 2.2rem; display: block; }

  /* ---- Alternating section bands ---- */
  .ym-{{ section.id }} .ym-band {
    border-radius: var(--ym-radius);
    margin-top: clamp(1.6rem, 3vw, 2.8rem);
    padding: clamp(2.8rem, 5vw, 5.4rem) clamp(1.8rem, 4vw, 4rem);
    position: relative;
    overflow: hidden;
  }
  .ym-{{ section.id }} .ym-band:first-child { margin-top: 0; }

  .ym-{{ section.id }} .ym-band--light {
    background: linear-gradient(160deg, #ffffff, var(--ym-cream));
    border: .1rem solid rgba(63, 77, 50, .1);
  }
  .ym-{{ section.id }} .ym-band--dark {
    background: linear-gradient(155deg, #1d1b24 0%, #141019 58%, #1b1524 100%);
    border: .1rem solid rgba(212, 175, 55, .26);
    color: #F4F2EC;
  }
  .ym-{{ section.id }} .ym-band--dark::before {
    content: ""; position: absolute; inset: 0 0 auto 0; height: .3rem;
    background: linear-gradient(90deg, transparent, var(--ym-gold), #f7e29a, transparent);
  }

  /* ---- Section heads ---- */
  .ym-{{ section.id }} .ym-head { max-width: 76rem; margin: 0 auto clamp(2.4rem, 4vw, 3.6rem); text-align: center; }
  .ym-{{ section.id }} .ym-eyebrow {
    align-items: center; color: var(--ym-pink); display: inline-flex; gap: .6rem;
    font-family: var(--ym-font-body); font-size: 1.2rem; font-weight: 700; letter-spacing: .16em;
    margin: 0 0 1rem; text-transform: uppercase;
  }
  .ym-{{ section.id }} .ym-eyebrow .ym-ico { width: 1.6rem; height: 1.6rem; color: var(--ym-green-soft); }
  .ym-{{ section.id }} .ym-head h2 { margin: 0; }
  .ym-{{ section.id }} .ym-lead { color: rgba(var(--color-foreground), .76); font-size: 1.6rem; line-height: 1.6; margin: 1.4rem 0 0; }

  .ym-{{ section.id }} .ym-band--dark .ym-eyebrow { color: var(--ym-gold); }
  .ym-{{ section.id }} .ym-band--dark .ym-eyebrow .ym-ico { color: var(--ym-pink); }
  .ym-{{ section.id }} .ym-band--dark .ym-head h2,
  .ym-{{ section.id }} .ym-band--dark h2,
  .ym-{{ section.id }} .ym-band--dark h3 { color: #fff; }
  .ym-{{ section.id }} .ym-band--dark .ym-lead { color: rgba(244, 242, 236, .76); }

  /* ---- Cards ---- */
  .ym-{{ section.id }} .ym-grid { display: grid; gap: 1.6rem; }
  .ym-{{ section.id }} .ym-card {
    background: rgb(var(--color-background));
    border: .1rem solid rgba(var(--color-foreground), .08);
    border-radius: var(--ym-radius);
    box-shadow: 0 1rem 2.6rem rgba(63, 77, 50, .07);
    padding: clamp(2rem, 3vw, 2.6rem);
  }
  .ym-{{ section.id }} .ym-card h3 { margin: 0 0 .6rem; }
  .ym-{{ section.id }} .ym-card p { color: rgba(var(--color-foreground), .74); line-height: 1.5; margin: 0; }

  .ym-{{ section.id }} .ym-band--dark .ym-card {
    background: rgba(255, 255, 255, .045);
    border-color: rgba(212, 175, 55, .22);
    box-shadow: none;
  }
  .ym-{{ section.id }} .ym-band--dark .ym-card p { color: rgba(244, 242, 236, .74); }

  /* ---- Icon chip ---- */
  .ym-{{ section.id }} .ym-chip {
    align-items: center; border-radius: 1.4rem; display: inline-flex; height: 4.6rem; width: 4.6rem;
    justify-content: center; margin-bottom: 1.4rem;
    background: linear-gradient(140deg, #EAF0DD, var(--ym-cream));
    color: var(--ym-green); border: .1rem solid rgba(63, 77, 50, .12);
  }
  .ym-{{ section.id }} .ym-chip--pink { background: linear-gradient(140deg, #FBE0EC, #FFF4F8); color: var(--ym-pink); border-color: rgba(224, 86, 140, .18); }
  .ym-{{ section.id }} .ym-chip--matcha { background: linear-gradient(140deg, #E4EDD2, var(--ym-cream)); color: var(--ym-green-soft); }

  .ym-{{ section.id }} .ym-band--dark .ym-chip { background: rgba(212, 175, 55, .12); border-color: rgba(212, 175, 55, .3); color: var(--ym-gold); }
  .ym-{{ section.id }} .ym-band--dark .ym-chip--pink,
  .ym-{{ section.id }} .ym-band--dark .ym-chip--danger { background: rgba(224, 86, 140, .14); border-color: rgba(224, 86, 140, .32); color: #F2A0BE; }
  .ym-{{ section.id }} .ym-band--dark .ym-chip--matcha { background: rgba(126, 143, 91, .16); border-color: rgba(126, 143, 91, .35); color: #BBD08A; }

  /* ---- Stars ---- */
  .ym-{{ section.id }} .ym-stars { color: var(--ym-gold); display: inline-flex; gap: .2rem; }
  .ym-{{ section.id }} .ym-stars .ym-ico { width: 1.8rem; height: 1.8rem; }

  /* ---- Hero ---- */
  .ym-{{ section.id }} .ym-band--hero { background: linear-gradient(150deg, #FBE0EC 0%, var(--ym-cream) 52%, #E4EDD2 100%); border-color: rgba(63, 77, 50, .12); }
  .ym-{{ section.id }} .ym-hero__inner { max-width: 70rem; position: relative; z-index: 1; }
  .ym-{{ section.id }} .ym-hero__inner h2 { margin: .6rem 0; }
  .ym-{{ section.id }} .ym-hero__sub { color: rgba(var(--color-foreground), .82); font-size: 1.7rem; line-height: 1.55; margin: 0 0 1rem; }
  .ym-{{ section.id }} .ym-hero__body { color: rgba(var(--color-foreground), .72); font-size: 1.5rem; line-height: 1.6; margin: 0; max-width: 60rem; }
  .ym-{{ section.id }} .ym-rating { align-items: center; display: flex; flex-wrap: wrap; gap: .8rem; margin-bottom: 1.4rem; }
  .ym-{{ section.id }} .ym-rating span { color: rgba(var(--color-foreground), .7); font-size: 1.4rem; }

  /* ---- Check bullet list ---- */
  .ym-{{ section.id }} .ym-checks { display: grid; gap: 1rem; list-style: none; margin: 2rem 0 0; padding: 0; }
  .ym-{{ section.id }} .ym-checks li { align-items: flex-start; display: flex; gap: 1rem; line-height: 1.4; }
  .ym-{{ section.id }} .ym-checks .ym-ico { color: var(--ym-green); flex-shrink: 0; margin-top: .1rem; width: 2rem; height: 2rem; }

  /* ---- Badge row ---- */
  .ym-{{ section.id }} .ym-badges { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 2rem; }
  .ym-{{ section.id }} .ym-badge {
    align-items: center; background: rgb(var(--color-background)); border: .1rem solid rgba(63, 77, 50, .16);
    border-radius: 999px; color: var(--ym-green); display: inline-flex; font-size: 1.2rem; font-weight: 700;
    gap: .6rem; letter-spacing: .04em; padding: .7rem 1.2rem; text-transform: uppercase;
  }
  .ym-{{ section.id }} .ym-badge .ym-ico { color: var(--ym-pink); width: 1.6rem; height: 1.6rem; }

  /* ---- CTA ---- */
  .ym-{{ section.id }} .ym-cta { display: inline-flex; margin-top: 2.2rem; }
  .ym-{{ section.id }} .ym-cta .button { gap: .8rem; font-family: var(--ym-font-body); }
  .ym-{{ section.id }} .ym-micro { color: rgba(var(--color-foreground), .6); font-size: 1.3rem; margin: 1.2rem 0 0; }

  /* ---- Before / After ---- */
  .ym-{{ section.id }} .ym-ba { align-items: center; display: grid; gap: 1.6rem; }
  .ym-{{ section.id }} .ym-ba__card { border-radius: var(--ym-radius); padding: clamp(2rem, 3vw, 2.8rem); border: .1rem solid; }
  .ym-{{ section.id }} .ym-ba__card--before { background: #FFF4F8; border-color: rgba(224, 86, 140, .25); }
  .ym-{{ section.id }} .ym-ba__card--after { background: #F1F6E7; border-color: rgba(63, 77, 50, .24); }
  .ym-{{ section.id }} .ym-ba__card h3 { margin: 0 0 1.4rem; color: var(--ym-green); }
  .ym-{{ section.id }} .ym-ba__card--before h3 { color: var(--ym-pink); }
  .ym-{{ section.id }} .ym-ba__list { display: grid; gap: 1rem; list-style: none; margin: 0; padding: 0; }
  .ym-{{ section.id }} .ym-ba__list li { align-items: flex-start; color: rgba(21, 19, 26, .82); display: flex; gap: 1rem; line-height: 1.4; }
  .ym-{{ section.id }} .ym-ba__list .ym-ico { flex-shrink: 0; width: 2rem; height: 2rem; }
  .ym-{{ section.id }} .ym-ba__card--before .ym-ico { color: var(--ym-pink); }
  .ym-{{ section.id }} .ym-ba__card--after .ym-ico { color: var(--ym-green); }
  .ym-{{ section.id }} .ym-ba__arrow {
    align-items: center; background: var(--ym-gold); border-radius: 50%; color: var(--ym-ink); display: flex;
    height: 4.4rem; width: 4.4rem; justify-content: center; margin: 0 auto; transform: rotate(90deg);
  }
  .ym-{{ section.id }} .ym-compliance { color: rgba(244, 242, 236, .68); font-size: 1.4rem; font-style: italic; margin: 1.8rem auto 0; max-width: 60rem; text-align: center; }

  .ym-{{ section.id }} .ym-card--ing h3 { font-size: 1.7rem; }

  /* ---- Taste ---- */
  .ym-{{ section.id }} .ym-taste { text-align: center; }
  .ym-{{ section.id }} .ym-taste__icons { display: flex; flex-wrap: wrap; gap: 1.2rem; justify-content: center; margin: 2rem 0; }
  .ym-{{ section.id }} .ym-taste__icons .ym-chip { margin: 0; }
  .ym-{{ section.id }} .ym-sensory { color: #fff; font-family: var(--ym-font-head); font-size: 2rem; line-height: 1.45; margin: 1.4rem auto 0; max-width: 56rem; }
  .ym-{{ section.id }} .ym-steps-mini {
    align-items: center; color: var(--ym-gold); display: inline-flex; flex-wrap: wrap; font-weight: 700;
    gap: .8rem; justify-content: center; letter-spacing: .04em; margin-top: 1.8rem; text-transform: uppercase;
  }
  .ym-{{ section.id }} .ym-steps-mini .ym-ico { color: var(--ym-pink); width: 1.4rem; height: 1.4rem; }

  /* ---- How to use steps ---- */
  .ym-{{ section.id }} .ym-step { position: relative; }
  .ym-{{ section.id }} .ym-step__n {
    align-items: center; background: var(--ym-green); border-radius: 50%; color: #fff; display: inline-flex;
    font-family: var(--ym-font-head); font-size: 1.3rem; font-weight: 700; height: 2.6rem; justify-content: center; position: absolute; right: 1.6rem; top: 1.6rem; width: 2.6rem;
  }
  .ym-{{ section.id }} .ym-tip {
    align-items: flex-start; background: var(--ym-cream); border: .1rem dashed rgba(63, 77, 50, .3);
    border-radius: var(--ym-radius); color: rgba(var(--color-foreground), .8); display: flex; gap: 1rem;
    margin-top: 1.6rem; padding: 1.6rem 2rem;
  }
  .ym-{{ section.id }} .ym-tip .ym-ico { color: var(--ym-gold); flex-shrink: 0; }

  /* ---- Comparison ---- */
  .ym-{{ section.id }} .ym-compare { display: grid; gap: 1.2rem; grid-template-columns: repeat(4, minmax(20rem, 1fr)); overflow-x: auto; padding-bottom: 1rem; scroll-snap-type: x mandatory; }
  .ym-{{ section.id }} .ym-compare__col { background: rgba(255, 255, 255, .05); border: .1rem solid rgba(212, 175, 55, .2); border-radius: var(--ym-radius); overflow: hidden; scroll-snap-align: start; }
  .ym-{{ section.id }} .ym-compare__head { padding: 1.6rem; text-align: center; }
  .ym-{{ section.id }} .ym-compare__head strong { display: block; font-family: var(--ym-font-head); font-size: 1.6rem; letter-spacing: .02em; }
  .ym-{{ section.id }} .ym-compare__head .ym-ico { color: var(--ym-gold); margin: 0 auto .8rem; width: 2.2rem; height: 2.2rem; }
  .ym-{{ section.id }} .ym-compare__rows { display: grid; gap: 0; list-style: none; margin: 0; padding: 1.6rem; }
  .ym-{{ section.id }} .ym-compare__rows li { align-items: flex-start; border-top: .1rem solid rgba(255, 255, 255, .08); color: rgba(244, 242, 236, .78); display: flex; font-size: 1.4rem; gap: .8rem; line-height: 1.35; padding: 1rem 0; }
  .ym-{{ section.id }} .ym-compare__rows li:first-child { border-top: 0; }
  .ym-{{ section.id }} .ym-compare__rows .ym-ico { flex-shrink: 0; width: 1.8rem; height: 1.8rem; }
  .ym-{{ section.id }} .ym-compare__col--lose .ym-compare__rows .ym-ico { color: #E58C73; }
  .ym-{{ section.id }} .ym-compare__col--win { border-color: var(--ym-gold); box-shadow: 0 1.4rem 3rem rgba(212, 175, 55, .18); }
  .ym-{{ section.id }} .ym-compare__col--win .ym-compare__head { background: linear-gradient(120deg, var(--ym-gold), #f7e29a); color: var(--ym-ink); position: relative; }
  .ym-{{ section.id }} .ym-compare__col--win .ym-compare__head .ym-ico { color: var(--ym-ink); }
  .ym-{{ section.id }} .ym-compare__col--win .ym-pickme { background: var(--ym-ink); border-radius: 999px; color: var(--ym-gold); font-size: 1rem; font-weight: 700; letter-spacing: .08em; padding: .3rem .8rem; position: absolute; right: 1rem; top: 1rem; text-transform: uppercase; }
  .ym-{{ section.id }} .ym-compare__col--win .ym-compare__rows .ym-ico { color: var(--ym-green-soft); }

  /* ---- Reviews ---- */
  .ym-{{ section.id }} .ym-review { background: linear-gradient(160deg, #ffffff, var(--ym-cream)); }
  .ym-{{ section.id }} .ym-review p { color: rgba(var(--color-foreground), .82); font-size: 1.5rem; line-height: 1.55; margin: 1rem 0 0; }
  .ym-{{ section.id }} .ym-review__name { align-items: center; color: var(--ym-green); display: flex; font-size: 1.3rem; font-weight: 700; gap: .6rem; margin-top: 1.4rem; }
  .ym-{{ section.id }} .ym-review__name .ym-ico { color: var(--ym-green-soft); width: 1.6rem; height: 1.6rem; }

  /* ---- FAQ ---- */
  .ym-{{ section.id }} .ym-faq { margin: 0 auto; max-width: 80rem; }
  .ym-{{ section.id }} .ym-faq__item { background: rgba(255, 255, 255, .05); border: .1rem solid rgba(212, 175, 55, .22); border-radius: var(--ym-radius); margin-top: 1.2rem; overflow: hidden; }
  .ym-{{ section.id }} .ym-faq__item summary { align-items: center; color: #fff; cursor: pointer; display: flex; font-family: var(--ym-font-head); font-size: 1.6rem; gap: 1.2rem; justify-content: space-between; list-style: none; padding: 1.8rem 2rem; }
  .ym-{{ section.id }} .ym-faq__item summary::-webkit-details-marker { display: none; }
  .ym-{{ section.id }} .ym-faq__ico { align-items: center; background: rgba(212, 175, 55, .16); border-radius: 50%; color: var(--ym-gold); display: inline-flex; flex-shrink: 0; height: 3rem; justify-content: center; width: 3rem; }
  .ym-{{ section.id }} .ym-faq__ico .ym-ico { width: 1.8rem; height: 1.8rem; }
  .ym-{{ section.id }} .ym-faq__item .ym-minus { display: none; }
  .ym-{{ section.id }} .ym-faq__item[open] .ym-plus { display: none; }
  .ym-{{ section.id }} .ym-faq__item[open] .ym-minus { display: inline-flex; }
  .ym-{{ section.id }} .ym-faq__item[open] .ym-faq__ico { background: var(--ym-gold); color: var(--ym-ink); }
  .ym-{{ section.id }} .ym-faq__a { color: rgba(244, 242, 236, .8); line-height: 1.6; padding: 0 2rem 2rem; }

  /* ---- Final CTA ---- */
  .ym-{{ section.id }} .ym-final { text-align: center; }
  .ym-{{ section.id }} .ym-final h2 { color: #fff; margin: 0 auto; max-width: 60rem; }
  .ym-{{ section.id }} .ym-final p { color: rgba(244, 242, 236, .82); font-size: 1.6rem; line-height: 1.6; margin: 1.6rem auto 0; max-width: 58rem; }
  .ym-{{ section.id }} .ym-final .ym-cta { justify-content: center; }
  .ym-{{ section.id }} .ym-final .ym-cta .button { --color-button: 212 175 55; --color-button-text: 20 20 27; }
  .ym-{{ section.id }} .ym-final .ym-badges { justify-content: center; }
  .ym-{{ section.id }} .ym-final .ym-badge { background: rgba(255, 255, 255, .06); border-color: rgba(212, 175, 55, .35); color: #F4F2EC; }
  .ym-{{ section.id }} .ym-final .ym-badge .ym-ico { color: var(--ym-gold); }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
